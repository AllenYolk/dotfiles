// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_profile": "write",
    "default_model": {
      "provider": "zed.dev",
      "model": "gemini-3.1-pro-preview",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "tree_view": true,
  },
  "ssh_connections": [
    {
      "host": "g3",
      "args": [],
      "projects": [
        {
          "paths": ["/home/allenyolk/CodeRepo/snn-online-learning"],
        },
        {
          "paths": ["/home/allenyolk/CodeRepo/spikingjelly-dev"],
        },
      ],
    },
  ],
  "ui_font_family": "Inter",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "mode": "eager",
    "provider": "copilot",
  },
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "terminal": {
    "dock": "bottom",
    "font_size": 13.0,
    "env": {
      "LANG": "\"en_US.UTF-8\"",
    },
    "font_family": "MesloLGS NF",
  },
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": false,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "off",
  },
  "soft_wrap": "editor_width",
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "ui_font_size": 15.0,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "ruff"],
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": false,
        "show_parameter_hints": true,
        "show_other_hints": true,
      },
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "diagnosticSeverityOverrides": {
            "reportArgumentType": "hint",
            "reportPossiblyUnboundVariable": "hint",
            "reportUnnecessaryComparison": "hint",
            "reportUntypedNamedTuple": "none",
            "reportAny": "none",
            "reportUnknownVariableType": "none",
            "reportUnknownParameterType": "none",
            "reportUnknownArgumentType": "none",
            "reportUnknownMemberType": "none",
            "reportUnusedCallResult": "none",
            "reportImplicitOverride": "none",
            "reportUnannotatedClassAttribute": "none",
            "reportDeprecated": "none",
            "reportMissingTypeArgument": "none",
            "reportMissingParameterType": "none",
            "reportImplicitStringConcatenation": "none",
            "reportIncompatibleMethodOverride": "none",
            "reportAttributeAccessIssue": "none",
            "reportOperatorIssue": "none",
            "reportIndexIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportOptionalOperand": "none",
            "reportCallIssue": "none",
            "reportAssignmentType": "none",
            "reportAbstractUsage": "none",
            "reportPrivateImportUsage": "none",
            "reportInvalidTypeForm": "none",
            "reportUninitializedInstanceVariable": "none",
          },
        },
      },
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lint": {
            "ignore": ["F403", "E402", "E731", "E741"],
          },
        },
      },
    },
  },
  "diagnostics_max_severity": "warning",
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": "warning",
    },
  },
}
